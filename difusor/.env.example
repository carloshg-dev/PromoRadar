# ─────────────────────────────────────────────────────────────────────────────
# Detec Difusor — copie para .env e preencha. TUDO read-only no site.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (SOMENTE LEITURA): a MESMA url e a anon key que o site ja usa.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                 # = NEXT_PUBLIC_SUPABASE_ANON_KEY do site (chave publica)

# Telegram — reaproveita o @PROMODETEC_BOT e a convencao do promo-feed.ts.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...     # token do @BotFather (mesmo do site)
TELEGRAM_FEED_CHAT_ID=@seucanalpublico   # canal PUBLICO de ofertas (ou -100123...). Bot precisa ser ADMIN.

# Discord — webhook de um canal publico de ofertas.
DISCORD_DEALS_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# ── Comportamento (opcionais — defaults sensatos) ────────────────────────────
SITE_URL=https://promodetec.vercel.app   # base do link rastreado /r/{id}
CRON=0 */3 * * *                         # de quanto em quanto tempo varre (padrao: a cada 3h)
RUN_ONCE=false                           # true = roda 1x e sai (ideal p/ cron externo / GitHub Actions)
BATCH=6                                  # quantas ofertas publica por rodada
POOL=80                                  # tamanho do balde lido antes de filtrar/dedup
MIN_DESCONTO=10                          # % minimo de desconto p/ entrar no feed
MIN_SCORE=0                              # promo_score minimo (0 = sem trava; suba conforme calibrar)
POST_DELAY_MS=1200                       # intervalo entre posts (respeita rate-limit do Telegram)
STATE_TTL_DAYS=30                        # apos N dias um id pode reaparecer no feed
BRAND_COLOR=0xFF6A39                     # cor dos embeds do Discord (coral PromoDetec)
STATE_FILE=data/posted.json              # onde guarda os ids ja publicados (monte volume no Docker)
