# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Chave service_role (NUNCA expor no client) — usada só pelos scrapers/cron
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Protege o endpoint de cron
CRON_SECRET=troque-isto

# URL pública canônica (metadata/OG/sitemap/canonical). Sem isto, usa o default em src/lib/site.ts.
NEXT_PUBLIC_SITE_URL=https://promodetec.vercel.app

# Mercado Livre (app de desenvolvedor — developers.mercadolivre.com.br)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://promodetec.vercel.app/api/auth/mercadolivre/callback

# Firecrawl (firecrawl.dev) — coleta hospedada p/ lojas de browser no cron da Vercel.
# Aceita VÁRIAS chaves separadas por vírgula (failover quando uma esgota a cota).
# Sem isto, Terabyte/Amazon/Pichau/Havan só coletam localmente (Playwright).
FIRECRAWL_API_KEY=fc-xxx,fc-yyy
